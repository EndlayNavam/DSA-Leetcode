For 2nd case, start = 0 , i =1 which makes nums[i] = nums[start] --->> [1,0,0....]

class Solution:
    def moveZeroes(self, nums: List[int]) -> None:
       start = 0
       n = len(nums)
       for i in range(n):
        if nums[i]!= 0:
            nums[i],nums[start] = nums[start],nums[i]
            start+=1
